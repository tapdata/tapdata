# Docker Compose Configuration
# 
# Controls which configuration files are loaded by default when running `docker-compose up`.
# Multiple files are separated by a colon (:).
#
# Mode 1: Local Build (Default)
# Compiles Tapdata from source code using the local Dockerfile.
# COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml

# Mode 2: Remote Image (Uncomment below to use)
# Uses the official image from ghcr.io/tapdata/tapdata:latest.
# COMPOSE_FILE=docker-compose.yml:docker-compose.remote.yml
COMPOSE_FILE=docker-compose.yml
COMPOSE_PARALLEL_LIMIT=2

# TM Service port, default is 3000
TM_PORT=3000
# TM Service JVM options
TM_JAVA_OPTS=--add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.security=ALL-UNNAMED --add-opens=java.base/sun.security.rsa=ALL-UNNAMED --add-opens=java.base/sun.security.x509=ALL-UNNAMED --add-opens=java.base/sun.security.util=ALL-UNNAMED --add-opens=java.xml/com.sun.org.apache.xerces.internal.jaxp.datatype=ALL-UNNAMED -Xms4g -Xmx4g

# Engine Service JVM options
ENGINE_JAVA_OPTS=--add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.security=ALL-UNNAMED --add-opens=java.base/sun.security.rsa=ALL-UNNAMED --add-opens=java.base/sun.security.x509=ALL-UNNAMED --add-opens=java.base/sun.security.util=ALL-UNNAMED --add-opens=java.xml/com.sun.org.apache.xerces.internal.jaxp.datatype=ALL-UNNAMED -XX:+UnlockExperimentalVMOptions --add-exports=java.base/jdk.internal.ref=ALL-UNNAMED --add-exports=java.base/sun.nio.ch=ALL-UNNAMED --add-exports=jdk.unsupported/sun.misc=ALL-UNNAMED --add-exports=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-modules=java.se --add-opens=java.management/sun.management=ALL-UNNAMED --add-opens=jdk.management/com.sun.management.internal=ALL-UNNAMED --add-opens=java.base/jdk.internal.loader=ALL-UNNAMED -Duser.timezone=Asia/Hong_Kong -Xms4g -Xmx4g

# Web Service port, default is 8080
WEB_PORT=3030

# MongoDB Service port, default is 27017
MONGO_PORT=27017
# MongoDB Service root username, default is admin
MONGO_INITDB_ROOT_USERNAME=admin
# MongoDB Service root password, default is tapdata_best2019
MONGO_INITDB_ROOT_PASSWORD=tapdata_best2019
